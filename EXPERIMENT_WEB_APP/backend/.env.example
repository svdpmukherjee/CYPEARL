# MongoDB
MONGO_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/"

# Scenario database names (choose any names you like)
PHISHING_DB_NAME="<phishing_db_name>"
DARKPATTERNS_DB_NAME="<dark_patterns_db_name>"
FAKENEWS_DB_NAME="<fake_news_db_name>"

# Comma-separated list of production frontend origins (no trailing slash).
# Example: https://your-app.vercel.app,https://your-domain.com
ALLOWED_ORIGINS=""

# Optional: only set these if you want S3 export enabled.
# Leave empty/unset to disable S3 export cleanly.
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="eu-west-1"
# S3_BUCKET_NAME=""

# Optional: only for the validator / improve_seed_emails scripts.
# OPENROUTER_API_KEY=""
